{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "Actions": [
    {
      "Name": "Recent Codex Project",
      "UUID": "com.codexstreamdeck.control.project-slot",
      "Icon": "imgs/action-project",
      "Tooltip": "Open a recent Codex task; hold for a safe status refresh.",
      "Controllers": [
        "Keypad"
      ],
      "SupportedInMultiActions": false,
      "UserTitleEnabled": false,
      "States": [
        {
          "Image": "imgs/key"
        }
      ]
    },
    {
      "Name": "Refresh Codex Projects",
      "UUID": "com.codexstreamdeck.control.refresh",
      "Icon": "imgs/action-refresh",
      "Tooltip": "Refresh Codex thread metadata and the local notify spool.",
      "Controllers": [
        "Keypad"
      ],
      "SupportedInMultiActions": true,
      "UserTitleEnabled": false,
      "States": [
        {
          "Image": "imgs/key"
        }
      ]
    },
    {
      "Name": "New Codex Task",
      "UUID": "com.codexstreamdeck.control.new-task",
      "Icon": "imgs/action-new",
      "Tooltip": "Start a configured task in the selected project.",
      "Controllers": [
        "Keypad"
      ],
      "SupportedInMultiActions": false,
      "UserTitleEnabled": false,
      "States": [
        {
          "Image": "imgs/key"
        }
      ]
    },
    {
      "Name": "Open Project in Editor",
      "UUID": "com.codexstreamdeck.control.open-editor",
      "Icon": "imgs/action-editor",
      "Tooltip": "Open the selected Codex project in the configured editor.",
      "Controllers": [
        "Keypad"
      ],
      "SupportedInMultiActions": true,
      "UserTitleEnabled": false,
      "States": [
        {
          "Image": "imgs/key"
        }
      ]
    },
    {
      "Name": "Review Project Changes",
      "UUID": "com.codexstreamdeck.control.review",
      "Icon": "imgs/action-review",
      "Tooltip": "Start a read-only review of uncommitted changes.",
      "Controllers": [
        "Keypad"
      ],
      "SupportedInMultiActions": false,
      "UserTitleEnabled": false,
      "States": [
        {
          "Image": "imgs/key"
        }
      ]
    },
    {
      "Name": "Interrupt Codex Turn",
      "UUID": "com.codexstreamdeck.control.interrupt",
      "Icon": "imgs/action-interrupt",
      "Tooltip": "Hold to interrupt a turn started by this plugin.",
      "Controllers": [
        "Keypad"
      ],
      "SupportedInMultiActions": false,
      "UserTitleEnabled": false,
      "States": [
        {
          "Image": "imgs/key"
        }
      ]
    },
    {
      "Name": "Codex Connection Health",
      "UUID": "com.codexstreamdeck.control.health",
      "Icon": "imgs/action-health",
      "Tooltip": "Show connection health; press to refresh or reconnect.",
      "Controllers": [
        "Keypad"
      ],
      "SupportedInMultiActions": false,
      "UserTitleEnabled": false,
      "States": [
        {
          "Image": "imgs/key"
        }
      ]
    },
    {
      "Name": "Open Codex Settings",
      "UUID": "com.codexstreamdeck.control.settings",
      "Icon": "imgs/action-settings",
      "Tooltip": "Open Codex settings.",
      "Controllers": [
        "Keypad"
      ],
      "SupportedInMultiActions": true,
      "UserTitleEnabled": false,
      "States": [
        {
          "Image": "imgs/key"
        }
      ]
    },
    {
      "Name": "Open Codex Skills",
      "UUID": "com.codexstreamdeck.control.skills",
      "Icon": "imgs/action-skills",
      "Tooltip": "Open the Codex skills page.",
      "Controllers": [
        "Keypad"
      ],
      "SupportedInMultiActions": true,
      "UserTitleEnabled": false,
      "States": [
        {
          "Image": "imgs/key"
        }
      ]
    }
  ],
  "Author": "Codex Stream Deck Contributors",
  "Category": "Codex Control",
  "CategoryIcon": "imgs/category",
  "CodePath": "bin/plugin.js",
  "Description": "Monitor recent Codex projects, open exact tasks, request safe status updates, and trigger common Codex actions.",
  "Icon": "imgs/plugin",
  "Name": "Codex Control",
  "Nodejs": {
    "Version": "24"
  },
  "OS": [
    {
      "Platform": "mac",
      "MinimumVersion": "13"
    },
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    }
  ],
  "PropertyInspectorPath": "ui/property-inspector.html",
  "SDKVersion": 3,
  "Software": {
    "MinimumVersion": "7.1"
  },
  "UUID": "com.codexstreamdeck.control",
  "Version": "0.1.0.0"
}