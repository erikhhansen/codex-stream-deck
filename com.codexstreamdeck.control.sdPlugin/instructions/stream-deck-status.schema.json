{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/codex-stream-deck/status-v1.schema.json",
  "title": "Codex Stream Deck Status Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "workflowStatus",
    "objective",
    "headline",
    "summary",
    "completed",
    "next",
    "blockers",
    "attention",
    "tests"
  ],
  "properties": {
    "version": { "type": "integer", "enum": [1] },
    "workflowStatus": {
      "type": "string",
      "enum": [
        "working",
        "needs_input",
        "blocked",
        "ready_for_review",
        "done",
        "paused",
        "failed",
        "unknown"
      ]
    },
    "objective": { "type": "string", "minLength": 1, "maxLength": 160 },
    "headline": { "type": "string", "minLength": 1, "maxLength": 42 },
    "summary": { "type": "string", "minLength": 1, "maxLength": 240 },
    "completed": {
      "type": "array",
      "maxItems": 8,
      "items": { "type": "string", "minLength": 1, "maxLength": 120 }
    },
    "next": {
      "type": "array",
      "maxItems": 8,
      "items": { "type": "string", "minLength": 1, "maxLength": 120 }
    },
    "blockers": {
      "type": "array",
      "maxItems": 8,
      "items": { "type": "string", "minLength": 1, "maxLength": 120 }
    },
    "attention": { "type": "string", "enum": ["none", "normal", "urgent"] },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "summary"],
      "properties": {
        "state": { "type": "string", "enum": ["not_run", "running", "passed", "failed", "unknown"] },
        "summary": { "type": "string", "minLength": 1, "maxLength": 160 }
      }
    }
  }
}
